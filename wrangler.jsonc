{
	"name": "ding-ee",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-04-01",
	"compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  }

}