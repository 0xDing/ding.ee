---
import BaseHead from '../../components/BaseHead.astro'
import BlogFeed from '../../components/BlogFeed.astro'
import Footer from '../../components/Footer.astro'
import Header from '../../components/Header.astro'
import HomeHero from '../../components/HomeHero.astro'
import { getSiteTitle } from '../../consts'
import { BCP47, isValidLocale, LOCALES, type Locale } from '../../i18n/config'
import { t } from '../../i18n/utils'
import { getLang, getLocalizedPosts, getLocalizedTagGroups } from '../../lib/content'

export function getStaticPaths() {
	return LOCALES.map(lang => ({ params: { lang } }))
}

const { lang } = Astro.params
if (!isValidLocale(lang)) return Astro.redirect('/')
const locale = lang as Locale

const [posts, tags] = await Promise.all([getLocalizedPosts(locale), getLocalizedTagGroups(locale)])
const pageTitle = t(locale, 'blog.index.title')
const pageDescription = t(locale, 'blog.index.description')
const fallbackNotice =
	posts.length > 0 && posts.every(post => getLang(post.id) !== locale)
		? t(locale, 'blog.feed.fallbackNotice', { lang: t(locale, `lang.${locale}`) })
		: undefined
---

<!doctype html>
<html lang={BCP47[locale]}>
	<head>
		<BaseHead title={getSiteTitle(locale)} description={pageDescription} lang={locale} path="" />
	</head>
	<body class="m-0 bg-page font-sans text-base leading-7 text-copy antialiased">
		<Header lang={locale} />
		<main class="mx-auto w-full max-w-300 px-4 pb-8 pt-4 sm:px-6 min-[721px]:pb-12 min-[721px]:pt-8">
			<HomeHero lang={locale} />
			<BlogFeed posts={posts} tags={tags} lang={locale} pageTitle={pageTitle} fallbackNotice={fallbackNotice} />
		</main>
		<Footer lang={locale} />
	</body>
</html>
