---
import type { CollectionEntry } from 'astro:content'
import type { MarkdownHeading } from 'astro'
import BaseHead from '../components/BaseHead.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import Footer from '../components/Footer.astro'
import FormattedDate from '../components/FormattedDate.astro'
import GiscusComments from '../components/GiscusComments.astro'
import Header from '../components/Header.astro'
import ProfileAvatar from '../components/ProfileAvatar.astro'
import type { Locale } from '../i18n/config'
import { BCP47 } from '../i18n/config'
import { localePath, t } from '../i18n/utils'
import { getTagSlug } from '../lib/content'

type BlogData = CollectionEntry<'blog'>['data']

type Props = Pick<BlogData, 'title' | 'description' | 'pubDate'> &
	Partial<Pick<BlogData, 'updatedDate' | 'heroImage' | 'tags'>> & {
			lang?: Locale
			headings?: MarkdownHeading[]
			readingMinutes?: number
			slug?: string
			fallbackLocale?: Locale
			originalLocale?: Locale
		}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
		headings = [],
		readingMinutes,
		lang: rawLang = 'en-US',
		slug,
		fallbackLocale,
		originalLocale
	} = Astro.props
const lang: Locale = rawLang ?? 'en'
const fallbackHref = fallbackLocale && slug ? localePath(fallbackLocale, slug) : undefined
const originalHref = originalLocale && slug ? localePath(originalLocale, slug) : undefined
const path = slug ? `${slug}` : undefined
const tocHeadings = headings.filter(heading => heading.depth === 2 || heading.depth === 3)
const hasSidebar = Boolean(readingMinutes) || tocHeadings.length > 0
---

<html lang={BCP47[lang]}>
	<head>
		<BaseHead title={title} description={description} image={heroImage} lang={lang} path={path} />
	</head>

	<body class="m-0 bg-page font-sans text-base leading-7 text-copy antialiased">
		<Header lang={lang} />
		<main class="mx-auto w-full max-w-300">
			<Breadcrumb lang={lang} items={[{ label: t(lang, 'blog.index.title'), href: localePath(lang) }, { label: title }]} />
			<article>
				<div class="px-4 pb-10 pt-4 sm:px-6 sm:pb-12 sm:pt-6">
					<div class:list={['mx-auto items-start gap-8 xl:gap-10', heroImage ? 'grid max-w-300 xl:grid-cols-2' : 'max-w-4xl']}>
						<div class="flex min-h-full flex-col">
							{
								tags.length > 0 && (
									<ul class="mb-5 flex list-none flex-wrap items-center gap-2 p-0">
										{
											tags.map(tag => (
												<li>
													<a
													href={localePath(lang, `tags/${getTagSlug(tag)}`)}
														class="inline-flex items-center rounded-full bg-secondary px-3 py-1.5 text-sm leading-none font-medium text-primary no-underline transition hover:bg-accent hover:text-primary-hover"
													>
														{tag}
													</a>
												</li>
											))
										}
									</ul>
								)
							}
							<h1 class="m-0  text-balance text-4xl leading-tight font-semibold text-ink">
								{title}
							</h1>
							<p class="mt-6 text-pretty text-base leading-8 text-muted-foreground sm:text-lg">
								{description}
							</p>
							<div class="mt-8 flex items-center gap-3">
								<ProfileAvatar size={32} alt={`${t(lang, 'hero.name')} avatar`} />
								<div>
									<p class="m-0 text-sm leading-none font-semibold text-ink">
										{t(lang, 'hero.name')}
									</p>
								
								</div>
							</div>
							<div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-3 text-sm text-subtle">
								<div class="font-medium text-copy">
									<FormattedDate date={pubDate} lang={lang} />
								</div>
								{
									updatedDate && (
										<div>
											{t(lang, 'blog.lastUpdated', {
												date: updatedDate.toLocaleDateString(BCP47[lang], {
													year: 'numeric',
													month: 'short',
													day: 'numeric',
												}),
											})}
										</div>
									)
								}
							</div>
						</div>
							{
								heroImage && (
									<div class="overflow-hidden rounded-[10px] border border-border bg-card shadow-xl">
										<img
											width={1440}
											height={810}
											src={heroImage.src}
											alt=""
											class="block aspect-video w-full object-cover"
										/>
									</div>
								)
							}
					</div>
				</div>
				<div class="px-4 pb-16 sm:px-6 sm:pb-20">
					<div class:list={['mx-auto border-t border-line pt-10 sm:pt-12', hasSidebar ? 'grid max-w-300 gap-10 xl:grid-cols-4 xl:gap-14' : 'max-w-3xl']}>
						{
							hasSidebar && (
								<aside class="space-y-4 xl:sticky xl:top-28 xl:col-span-1 xl:self-start">
									{
										readingMinutes && (
											<div class="rounded-2xl border border-border bg-card p-5 shadow-lg">
												<p class="m-0 text-sm leading-none font-semibold text-ink">
													{t(lang, 'blog.readingTime', { minutes: readingMinutes })}
												</p>
												<div class="mt-4 h-2 rounded-full bg-muted">
													<div
														class="h-full rounded-full bg-linear-to-r from-primary via-[#7ca8ff] to-[#bfd4ff]"
														style={`width: ${Math.min(100, Math.max(22, readingMinutes * 15))}%`}
													></div>
												</div>
											</div>
										)
									}
									{
										tocHeadings.length > 0 && (
											<nav class="rounded-2xl border border-border bg-card p-5 shadow-lg">
												<p class="m-0 text-sm leading-none font-semibold tracking-widest text-subtle uppercase">
													{t(lang, 'blog.contents')}
												</p>
												<ul class="mt-5 list-none space-y-3 p-0">
													{
														tocHeadings.map(heading => (
															<li class:list={[heading.depth === 3 && 'pl-4']}>
																<a
																	href={`#${heading.slug}`}
																	class:list={[
																		'block text-balance no-underline transition hover:text-primary',
																		heading.depth === 2 ? 'font-semibold text-ink' : 'text-copy'
																	]}
																>
																	{heading.text}
																</a>
															</li>
														))
													}
												</ul>
											</nav>
										)
									}
								</aside>
							)
						}
							<div class="min-w-0 xl:col-span-3">
								<div
									class="prose prose-zinc dark:prose-invert max-w-none prose-headings:mb-3 prose-headings:font-semibold prose-headings:leading-tight prose-h2:mt-14 prose-h2:text-3xl prose-h3:mt-10 prose-h3:text-2xl prose-h4:mt-8 prose-h4:text-xl prose-p:mb-8 prose-p:leading-8 prose-a:text-primary prose-a:no-underline hover:prose-a:text-primary-hover prose-strong:font-bold prose-strong:text-ink prose-blockquote:my-10 prose-blockquote:border-l-4 prose-blockquote:border-primary prose-blockquote:pl-6 prose-blockquote:text-xl prose-blockquote:font-normal prose-blockquote:not-italic prose-blockquote:text-ink prose-hr:my-10 prose-hr:border-line prose-img:rounded-2xl prose-pre:my-8 prose-pre:overflow-x-auto prose-pre:rounded-2xl prose-pre:bg-ink prose-pre:px-6 prose-pre:py-6 prose-pre:font-mono prose-pre:text-sm prose-pre:leading-relaxed prose-pre:text-white prose-code:rounded-sm prose-code:bg-line prose-code:px-1 prose-code:py-0.5 prose-code:font-mono prose-code:text-sm prose-code:text-ink prose-ul:mb-8 prose-ol:mb-8 prose-li:my-2 prose-table:mb-8 prose-table:w-full prose-th:border prose-th:border-line prose-th:px-3 prose-th:py-2 prose-th:text-left prose-th:text-ink prose-td:border prose-td:border-line prose-td:px-3 prose-td:py-2 [&_blockquote_p]:mb-0 [&_code::before]:content-none [&_code::after]:content-none [&_pre_code]:rounded-none [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-inherit [&_pre_code::before]:content-none [&_pre_code::after]:content-none [&_h2]:scroll-mt-28 [&_h3]:scroll-mt-28 [&_textarea]:w-full [&>p:first-of-type]:text-base [&>p:first-of-type]:leading-8 [&>p:first-of-type]:font-medium [&>p:first-of-type]:text-ink"
									>
										{
											fallbackLocale && fallbackHref && (
												<div class="rounded-md border border-border bg-yellow-50 p-4 text-sm text-subtle dark:bg-yellow-950" role="alert">
													<p
														class="not-prose"
														set:html={
															'⚠️ ' +
															t(lang, 'blog.fallback.notice', {
																requestedLang: t(lang, `lang.${lang}`),
																availableLang: t(lang, `lang.${fallbackLocale}`),
																linkStart: `<a href="${fallbackHref}" class="font-medium text-primary no-underline hover:text-primary-hover">`,
																linkEnd: '</a>',
															})
														}
													/>
												</div>
											)
										}
										{
											originalLocale && originalHref && (
												<div class="rounded-md border border-border bg-yellow-50 p-4 text-sm text-subtle dark:bg-yellow-950" role="alert">
													<p
														class="not-prose"
													set:html={
														'⚠️ ' +
														t(lang, 'blog.translation.notice', {
															lang: t(lang, `lang.${originalLocale}`),
															linkStart: `<a href="${originalHref}" class="font-medium text-primary no-underline hover:text-primary-hover">`,
															linkEnd: '</a>',
														})
													}
												/>
											</div>
										)
									}
									<slot />
								</div>
								<GiscusComments lang={lang} />
							</div>
						</div>
					</div>
				</article>
		</main>
		<Footer lang={lang} />
	</body>
</html>
