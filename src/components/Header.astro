---
import { Menu as MenuIcon } from 'lucide-react'
import LanguageDropdown from '@/common/components/LanguageDropdown'
import ThemeToggle from '@/common/components/ThemeToggle'
import { getSiteTitle } from '../consts'
import { LOCALE_LABELS, LOCALES, type Locale } from '../i18n/config'
import { localePath, t } from '../i18n/utils'
import HeaderBrand from './header/HeaderBrand.astro'
import HeaderNavLinks from './header/HeaderNavLinks.astro'

interface Props {
	lang: Locale
}

const { lang } = Astro.props
const pathname = Astro.url.pathname
const pathWithoutLang = pathname.replace(new RegExp(`^/${lang}(/|$)`), '/')
const rssHref = `/${lang}/rss.xml`
const siteTitle = getSiteTitle(lang)
const mobileMenuId = `site-nav-toggle-${lang}`

function normalizePath(value: string): string {
	const normalized = value.replace(/\/+$/, '')
	return normalized || '/'
}

const currentPath = normalizePath(pathname)
const isActiveLink = (href: string) => normalizePath(href) === currentPath
const navItems = [
	{ href: localePath(lang), label: t(lang, 'nav.home') },
	{ href: localePath(lang, 'projects'), label: t(lang, 'nav.projects') },
	{ href: localePath(lang, 'about'), label: t(lang, 'nav.about') }
].map(item => ({
	...item,
	active: isActiveLink(item.href)
}))
const localeItems = LOCALES.map(locale => ({
	href: `/${locale}${pathWithoutLang === '/' ? '/' : pathWithoutLang}`,
	label: LOCALE_LABELS[locale],
	active: locale === lang
}))
---

<header class="relative z-40">
	<div
		class="mx-auto max-w-300 isolate  bg-linear-to-b from-surface/96 via-surface/88 to-surface/78 shadow-2xl backdrop-blur-xl backdrop-saturate-150 supports-backdrop-filter:bg-surface/74 sm:mt-6 sm:rounded-2xl"
	>
		<div class="w-full">
			<input id={mobileMenuId} type="checkbox" class="peer sr-only sm:hidden" />

			<div class="flex min-h-16 items-center gap-3 py-3 sm:px-5 sm:py-0">
				<HeaderBrand
					href={localePath(lang)}
					label={siteTitle}
					class="relative z-10 min-w-0 flex-1 sm:flex-none sm:shrink-0"
					logoClass="h-7.25 w-7.25 shrink-0 sm:h-6 sm:w-auto"
					textClass="truncate sm:overflow-visible"
				/>

				<nav class="pointer-events-auto absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 items-center justify-center gap-1 sm:flex">
					<HeaderNavLinks items={navItems} variant="desktop" />
				</nav>

				<div class="relative z-10 ml-auto flex shrink-0 items-center sm:gap-3">
					<div class="flex w-12 items-center justify-center sm:w-auto">
						<LanguageDropdown client:load label={t(lang, 'nav.languages')} items={localeItems} />
					</div>

					<div class="hidden h-3 w-px rounded-full bg-black/12 sm:block"></div>

					<div class="flex w-12 items-center justify-center sm:w-auto">
						<ThemeToggle client:only="react" />
					</div>

					<label
						for={mobileMenuId}
						class="flex w-12 cursor-pointer items-center justify-center text-subtle transition hover:text-foreground sm:hidden"
					>
						<span class="sr-only">{t(lang, 'nav.menu')}</span>
						<MenuIcon aria-hidden="true" className="size-7" strokeWidth={1.8} />
					</label>
				</div>
			</div>

			<div class="hidden pb-3 peer-checked:block sm:hidden">
				<div class="rounded-2xl border border-white/40 dark:border-black/40 bg-linear-to-b from-surface/96 via-surface/90 to-surface/84 p-3 shadow-frosted backdrop-blur-xl backdrop-saturate-150 supports-backdrop-filter:bg-surface/80">
					<div class="flex flex-col gap-1">
						<HeaderNavLinks items={navItems} variant="mobile" />
					</div>

					<div class="mt-3">
						<a
							href={rssHref}
							class="flex items-center justify-center rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-foreground no-underline transition hover:bg-primary-hover"
						>
							RSS
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</header>
