---
import type { Locale } from '../i18n/config'

type Props = {
	lang: Locale
}

const GISCUS_LANG: Record<Locale, string> = {
	'en-US': 'en',
	'zh-Hans-CN': 'zh-CN',
	'ja-JP': 'ja',
}

const GISCUS_THEME = {
	light: 'light_tritanopia',
	dark: 'dark_tritanopia',
} as const

const { lang }: Props = Astro.props
const giscusLang = GISCUS_LANG[lang]
---

<section class="not-prose mt-14 border-t border-line pt-10" aria-label="Comments">
	<div data-giscus-root></div>
</section>

<script
	define:vars={{
		giscusLang,
		lightTheme: GISCUS_THEME.light,
		darkTheme: GISCUS_THEME.dark,
	}}
	is:inline
>
	const host = document.currentScript?.previousElementSibling
	const container = host?.querySelector('[data-giscus-root]')

	if (container instanceof HTMLDivElement) {
		const resolveTheme = () =>
			document.documentElement.classList.contains('dark') ? darkTheme : lightTheme

		const syncTheme = theme => {
			const iframe = document.querySelector('iframe.giscus-frame')
			iframe?.contentWindow?.postMessage(
				{ giscus: { setConfig: { theme } } },
				'https://giscus.app'
			)
		}

		if (!container.childElementCount) {
			const script = document.createElement('script')
			script.src = 'https://giscus.app/client.js'
			script.async = true
			script.crossOrigin = 'anonymous'
			script.setAttribute('data-repo', '0xding/ding.ee')
			script.setAttribute('data-repo-id', 'R_kgDOR919Ww')
			script.setAttribute('data-category', 'Announcements')
			script.setAttribute('data-category-id', 'DIC_kwDOR919W84C6c2y')
			script.setAttribute('data-mapping', 'pathname')
			script.setAttribute('data-strict', '0')
			script.setAttribute('data-reactions-enabled', '1')
			script.setAttribute('data-emit-metadata', '1')
			script.setAttribute('data-input-position', 'top')
			script.setAttribute('data-theme', resolveTheme())
			script.setAttribute('data-lang', giscusLang)
			script.setAttribute('data-loading', 'lazy')
			container.appendChild(script)
		}

		let theme = resolveTheme()
		const observer = new MutationObserver(() => {
			const nextTheme = resolveTheme()
			if (nextTheme === theme) return
			theme = nextTheme
			syncTheme(nextTheme)
		})

		observer.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['class'],
		})

		window.addEventListener(
			'pagehide',
			() => {
				observer.disconnect()
			},
			{ once: true }
		)
	}
</script>
