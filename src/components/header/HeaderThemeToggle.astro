---
const lightLabel = 'Switch to dark mode'
const darkLabel = 'Switch to light mode'
---

<button
	type="button"
	data-theme-toggle
	data-light-label={lightLabel}
	data-dark-label={darkLabel}
	aria-label={lightLabel}
	class="flex cursor-pointer items-center justify-center rounded-full text-subtle transition hover:text-foreground focus-visible:outline-none focus-visible:text-foreground"
>
	<svg
		data-theme-icon="moon"
		aria-hidden="true"
		viewBox="0 0 24 24"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
		class="size-5"
	>
		<path
			d="M20.354 15.354A9 9 0 0 1 8.646 3.646a9 9 0 1 0 11.708 11.708Z"
			stroke="currentColor"
			stroke-width="1.8"
			stroke-linecap="round"
			stroke-linejoin="round"
		/>
	</svg>
	<svg
		data-theme-icon="sun"
		aria-hidden="true"
		viewBox="0 0 24 24"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
		class="hidden size-5"
	>
		<circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" />
		<path d="M12 2.5V5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
		<path d="M12 19V21.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
		<path d="M4.93 4.93 6.7 6.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
		<path d="M17.3 17.3 19.07 19.07" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
		<path d="M2.5 12H5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
		<path d="M19 12h2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
		<path d="M4.93 19.07 6.7 17.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
		<path d="M17.3 6.7 19.07 4.93" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
	</svg>
</button>

<script is:inline>
	(() => {
		const getResolvedTheme = () => {
			const stored = localStorage.getItem('theme')
			if (stored) {
				try {
					return JSON.parse(stored)
				} catch {
					return stored
				}
			}

			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
		}

		const syncButton = button => {
			const isDark = document.documentElement.classList.contains('dark')
			const moonIcon = button.querySelector('[data-theme-icon="moon"]')
			const sunIcon = button.querySelector('[data-theme-icon="sun"]')
			const nextLabel = isDark ? button.dataset.darkLabel : button.dataset.lightLabel

			button.setAttribute('aria-label', nextLabel ?? '')
			moonIcon?.classList.toggle('hidden', isDark)
			sunIcon?.classList.toggle('hidden', !isDark)
		}

		const bindToggle = button => {
			if (button.dataset.bound === 'true') return
			button.dataset.bound = 'true'
			syncButton(button)

			button.addEventListener('click', () => {
				const nextTheme = getResolvedTheme() === 'dark' ? 'light' : 'dark'
				localStorage.setItem('theme', JSON.stringify(nextTheme))
				document.documentElement.classList.toggle('dark', nextTheme === 'dark')
				syncButton(button)
			})
		}

		const init = () => {
			document.querySelectorAll('[data-theme-toggle]').forEach(bindToggle)
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init, { once: true })
		} else {
			init()
		}
	})()
</script>
