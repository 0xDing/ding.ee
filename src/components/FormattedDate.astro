---
import type { Locale } from '../i18n/config'
import { BCP47 } from '../i18n/config'

interface Props {
	date: Date
	lang?: Locale
}

const { date, lang = 'en-US' } = Astro.props
const bcp = BCP47[lang]
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(bcp, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
